	cd /home/lxy/Desktop/binexport/binexport/build_linux && $(MAKE) $(MAKESILENT) -f _deps/binaryninjaapi-build/CMakeFiles/binaryninjaapi.dir/build.make _deps/binaryninjaapi-build/CMakeFiles/binaryninjaapi.dir/websocketprovider.cpp.i
.PHONY : websocketprovider.cpp.i

