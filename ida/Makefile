	cd /home/lxy/Desktop/binexport/binexport/build_linux && $(MAKE) $(MAKESILENT) -f ida/CMakeFiles/binexport_plugin_shared_ea64.dir/build.make ida/CMakeFiles/binexport_plugin_shared_ea64.dir/util.cc.s
.PHONY : util.cc.s

